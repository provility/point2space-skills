{"expression":"translateclone","_requires":["g2d"],"description":"Creates translated copies of a shape along dx, dy offsets.","utility":"Create translated copies of a 2D shape","arguments":[{"name":"graph","type":"g2d","required":true,"description":"Graph container"},{"name":"shape","type":"variable","required":true,"description":"Shape to clone"},{"name":"dx","type":"number","required":true,"description":"X offset per copy"},{"name":"dy","type":"number","required":true,"description":"Y offset per copy"},{"name":"count","type":"number","required":true,"description":"Number of copies"}],"examples":[{"scenario":"5 translated squares","expression":"G = g2d(at(4,4), size(25), type(geometry))\nsq = square(G, point(G, 0, 0), 2)\ntranslateclone(G, sq, 3, 0, 5, c(blue))"},{"scenario":"Vertical copies","expression":"translateclone(G, circle_1, 0, 3, 4, c(teal))"}]}
