{"expression":"vector3danimator","_requires":["g3d","vector3d"],"description":"Attaches a mutator to a 3D vector for animation.","utility":"Animate a 3D vector to a new direction","arguments":[{"name":"vectorRef","type":"vector3d variable","required":true,"description":"Vector to animate"},{"name":"target","type":"vector3d expression","required":true,"description":"Target vector definition"}],"examples":[{"scenario":"Animate vector direction","expression":"V = vector3d(G, 0, 0, 0, 1, 0, 0, c(red))\nvector3danimator(V, vector3d(G, 0, 0, 0, 0, 1, 0))"},{"scenario":"Animate to diagonal","expression":"vector3danimator(V, vector3d(G, 0, 0, 0, 1, 1, 1))"}]}
