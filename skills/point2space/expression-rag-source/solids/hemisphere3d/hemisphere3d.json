{
  "expression": "hemisphere3d",
  "_requires": [],
  "description": "Standalone ThreeJS hemisphere solid. Uses at() and view() for positioning.",
  "utility": "Create a 3D hemisphere solid",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": false, "description": "Container size"},
    {"name": "radius", "type": "number", "required": true, "description": "Hemisphere radius"},
    {"name": "color", "type": "c(color)", "required": false, "description": "Edge color"},
    {"name": "fillColor", "type": "fc(color)", "required": false, "description": "Fill color"},
    {"name": "fillOpacity", "type": "fo(number)", "required": false, "description": "Fill opacity (0-1)"}
  ],
  "examples": [
    {"scenario": "Hemisphere with styling", "expression": "S = hemisphere3d(at(4,4), view(14,14), 3, c(navy), fc(lightyellow), fo(0.5))"},
    {"scenario": "Small hemisphere", "expression": "S = hemisphere3d(at(4,4), view(10,10), 2, c(teal))"}
  ]
}
