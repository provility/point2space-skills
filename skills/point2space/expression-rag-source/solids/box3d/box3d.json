{
  "expression": "box3d",
  "_requires": [],
  "description": "Standalone ThreeJS rectangular box solid. Uses at() and view() for positioning.",
  "utility": "Create a 3D rectangular box solid",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": false, "description": "Container size"},
    {"name": "width", "type": "number", "required": true, "description": "Box width"},
    {"name": "height", "type": "number", "required": true, "description": "Box height"},
    {"name": "depth", "type": "number", "required": true, "description": "Box depth"},
    {"name": "color", "type": "c(color)", "required": false, "description": "Edge color"},
    {"name": "fillColor", "type": "fc(color)", "required": false, "description": "Fill color"},
    {"name": "fillOpacity", "type": "fo(number)", "required": false, "description": "Fill opacity (0-1)"}
  ],
  "examples": [
    {"scenario": "Box with dimensions", "expression": "S = box3d(at(4,4), view(14,14), 4, 3, 2, c(navy), fc(lightyellow), fo(0.5))"},
    {"scenario": "Tall narrow box", "expression": "S = box3d(at(4,4), view(14,14), 1, 5, 1, c(steelblue))"}
  ]
}
