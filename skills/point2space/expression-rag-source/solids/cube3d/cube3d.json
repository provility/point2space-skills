{
  "expression": "cube3d",
  "_requires": [],
  "description": "Standalone ThreeJS cube solid. Uses at() and view() for positioning.",
  "utility": "Create a 3D cube solid",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": false, "description": "Container size (default 10, 8)"},
    {"name": "sideLength", "type": "number", "required": true, "description": "Edge length of the cube"},
    {"name": "color", "type": "c(color)", "required": false, "description": "Edge color"},
    {"name": "fillColor", "type": "fc(color)", "required": false, "description": "Fill color"},
    {"name": "fillOpacity", "type": "fo(number)", "required": false, "description": "Fill opacity (0-1)"}
  ],
  "examples": [
    {"scenario": "Cube with styling", "expression": "S = cube3d(at(4,4), view(14,14), 3, c(navy), fc(lightyellow), fo(0.5))"},
    {"scenario": "Simple cube", "expression": "S = cube3d(at(4,4), view(12,12), 2)"}
  ]
}
