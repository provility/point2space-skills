{
  "expression": "cylinder3d",
  "_requires": [],
  "description": "Standalone ThreeJS cylinder solid. Uses at() and view() for positioning.",
  "utility": "Create a 3D cylinder solid",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": false, "description": "Container size"},
    {"name": "radius", "type": "number", "required": true, "description": "Cylinder radius"},
    {"name": "height", "type": "number", "required": true, "description": "Cylinder height"},
    {"name": "color", "type": "c(color)", "required": false, "description": "Edge color"},
    {"name": "fillColor", "type": "fc(color)", "required": false, "description": "Fill color"},
    {"name": "fillOpacity", "type": "fo(number)", "required": false, "description": "Fill opacity (0-1)"}
  ],
  "examples": [
    {"scenario": "Cylinder with styling", "expression": "S = cylinder3d(at(4,4), view(14,14), 2, 5, c(navy), fc(lightyellow), fo(0.5))"},
    {"scenario": "Short wide cylinder", "expression": "S = cylinder3d(at(4,4), view(14,14), 4, 1, c(teal), fc(lightcyan), fo(0.4))"}
  ]
}
