{
  "expression": "pyramid3d",
  "_requires": [],
  "description": "Standalone ThreeJS regular pyramid solid. Uses at() and view() for positioning.",
  "utility": "Create a regular pyramid with specified number of base sides",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": false, "description": "Container size"},
    {"name": "sides", "type": "number", "required": true, "description": "Number of base sides (default 4)"},
    {"name": "color", "type": "c(color)", "required": false, "description": "Edge color"},
    {"name": "fillColor", "type": "fc(color)", "required": false, "description": "Fill color"},
    {"name": "fillOpacity", "type": "fo(number)", "required": false, "description": "Fill opacity (0-1)"}
  ],
  "examples": [
    {"scenario": "Square pyramid", "expression": "S = pyramid3d(at(4,4), view(14,14), 4, c(navy), fc(lightyellow), fo(0.5))"},
    {"scenario": "Triangular pyramid", "expression": "S = pyramid3d(at(4,4), view(14,14), 3, c(brown), fc(wheat), fo(0.4))"}
  ]
}
