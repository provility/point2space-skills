{
  "expression": "revolvewasher",
  "_requires": ["g2d", "region"],
  "description": "Solid of revolution using the washer method. Takes outer and inner 2D regions and revolves around an axis.",
  "utility": "Visualize solids of revolution with hollow center (washer method)",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": true, "description": "View size"},
    {"name": "outerRegion", "type": "region reference", "required": true, "description": "Outer boundary region"},
    {"name": "innerRegion", "type": "inner(region) or region reference", "required": true, "description": "Inner boundary region"},
    {"name": "axis", "type": "axis(x) or axis(y)", "required": true, "description": "Axis of revolution"},
    {"name": "fillColor", "type": "fc(color)", "required": false, "description": "Fill color"},
    {"name": "rulings", "type": "rulings3d(count)", "required": false, "description": "Number of ruling lines"},
    {"name": "sweep", "type": "sweep(start, end)", "required": false, "description": "Sweep angle range"}
  ],
  "examples": [
    {
      "scenario": "Washer method around x-axis",
      "expression": "region_1=region(graph_1, plot_1, line_1, line_2, line_3)\nregion_2=region(graph_1, plot_2, line_1, line_2, line_3, fc(pink))\nrevolve_1=revolvewasher(at(2,1),view(17,16.9),region_1,region_2,axis(x),fc(red),rulings3d(64),sweep(0,360),slice(0.5))"
    }
  ],
  "_note": "Pipeline: g2d -> plot/line -> region() -> revolvewasher."
}
