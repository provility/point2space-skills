{
  "expression": "permutation",
  "_requires": [],
  "description": "Shows all ordered arrangements of r items from n elements. Standalone visualization.",
  "utility": "Generate permutations from a set",
  "arguments": [
    {"name": "position", "type": "at(row, col)", "required": true, "description": "Canvas position"},
    {"name": "viewSize", "type": "view(h, w)", "required": false, "description": "Container size"},
    {"name": "elements", "type": "set()", "required": true, "description": "Element set definition"},
    {"name": "selectCount", "type": "choose(n)", "required": false, "description": "Number of items to select (default: 1)"}
  ],
  "examples": [
    {"scenario": "Permutations of 3 from 4", "expression": "P = permutation(at(4,4), view(14,20), set(\"A\", \"B\", \"C\", \"D\"), choose(3))"},
    {"scenario": "All permutations of 3 items", "expression": "P = permutation(at(4,4), view(14,20), set(1, 2, 3), choose(3))"}
  ]
}
