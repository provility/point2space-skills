{
  "expression": "vecdiff",
  "_requires": ["g2d", "vector"],
  "description": "Subtracts one vector from another (A minus B) to produce a difference vector. The result starts at the first vector's start point by default, or at a specified point.",
  "utility": "Subtract two vectors to produce a difference vector (A - B)",
  "arguments": [
    {
      "name": "graph",
      "type": "g2d",
      "required": true,
      "description": "Graph container created with g2d()"
    },
    {
      "name": "vectorA",
      "type": "vector | line",
      "required": true,
      "description": "Vector to subtract from (minuend)"
    },
    {
      "name": "vectorB",
      "type": "vector | line",
      "required": true,
      "description": "Vector to subtract (subtrahend)"
    },
    {
      "name": "startPoint",
      "type": "point",
      "required": false,
      "description": "Optional point where the result vector starts"
    }
  ],
  "alternates": [
    {
      "variant": "Basic difference from first vector's start",
      "syntax": "vecdiff(G, V1, V2)",
      "description": "Subtract vectors (V1 - V2), result starts at V1's start point"
    },
    {
      "variant": "Difference placed at a point",
      "syntax": "vecdiff(G, V1, V2, point)",
      "description": "Subtract vectors, result starts at the given point"
    }
  ],
  "examples": [
    {
      "scenario": "Create graph and define points",
      "expression": "G = g2d(at(8,0), 20, type(geometry))"
    },
    {
      "scenario": "Points for first vector",
      "expression": "A = point(G, 0, 0)"
    },
    {
      "scenario": "End point",
      "expression": "B = point(G, 5, 3)"
    },
    {
      "scenario": "First vector",
      "expression": "V1 = vector(G, A, B)"
    },
    {
      "scenario": "Second vector using position form",
      "expression": "V2 = vector(G, 2, 1, type(position))"
    },
    {
      "scenario": "Difference V1 - V2",
      "expression": "diff_1 = vecdiff(G, V1, V2)"
    },
    {
      "scenario": "Difference placed at a point",
      "expression": "diff_2 = vecdiff(G, V1, V2, point(G, -3, 0))"
    },
    {
      "scenario": "Styled difference vector in orange",
      "expression": "diff_3 = vecdiff(G, V1, V2, c(orange))"
    }
  ]
}
