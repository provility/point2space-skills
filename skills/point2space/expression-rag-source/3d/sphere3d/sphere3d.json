{
  "expression": "sphere3d",
  "_requires": ["g3d"],
  "description": "Creates a sphere from center point and radius in 3D space within a g3d container.",
  "utility": "Create a sphere in 3D space",
  "arguments": [
    {"name": "graph", "type": "g3d", "required": true, "description": "3D graph container"},
    {"name": "center", "type": "point3d", "required": true, "description": "Center point"},
    {"name": "radius", "type": "number", "required": true, "description": "Sphere radius"}
  ],
  "examples": [
    {"scenario": "Sphere at origin", "expression": "G = g3d(at(4,23), view(30, 30))\nC = point3d(G, 0, 0, 0)\nsph = sphere3d(G, C, 3, fc(lightblue), fo(0.3))"},
    {"scenario": "Off-center sphere", "expression": "sph = sphere3d(G, point3d(G, 2, 1, 3), 2, c(red), fo(0.2))"}
  ]
}
