{
  "expression": "branch",
  "_requires": ["ptree"],
  "description": "Adds a branch to a probability tree with label and probability (numerator/denominator).",
  "utility": "Add a branch to a probability tree",
  "arguments": [
    {"name": "ptree", "type": "ptree variable", "required": true, "description": "Reference to probability tree"},
    {"name": "label", "type": "quoted string", "required": true, "description": "Branch label"},
    {"name": "numerator", "type": "number", "required": false, "description": "Probability numerator (default: 1)"},
    {"name": "denominator", "type": "number", "required": false, "description": "Probability denominator (default: 1)"},
    {"name": "spacing", "type": "buff(gap)", "required": false, "description": "Branch spacing"}
  ],
  "examples": [
    {"scenario": "Two branches", "expression": "G = g2d(at(4,4), size(20), type(geometry))\nT = ptree(G, \"H:0.5\", \"T:0.5\")\nbranch(T, \"H\", 1, 2)\nbranch(T, \"T\", 1, 2)"},
    {"scenario": "Three branches", "expression": "branch(T, \"R\", 1, 3)\nbranch(T, \"G\", 1, 3)\nbranch(T, \"B\", 1, 3)"}
  ]
}
