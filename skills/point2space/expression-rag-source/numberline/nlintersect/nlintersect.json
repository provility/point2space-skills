{
  "expression": "nlintersect",
  "_requires": ["nl"],
  "description": "Computes the intersection of exactly 2 operand sets on a number line. Operands can be interval, ray, ineq, absineq, or other set operation results.",
  "utility": "Compute and visualize intersection of two sets on a number line",
  "arguments": [
    {
      "name": "numberLine",
      "type": "nl variable",
      "required": true,
      "description": "Number line variable"
    },
    {
      "name": "operandA",
      "type": "variable ref",
      "required": true,
      "description": "First interval/set-op variable"
    },
    {
      "name": "operandB",
      "type": "variable ref",
      "required": true,
      "description": "Second interval/set-op variable"
    },
    {
      "name": "color",
      "type": "c(color)",
      "required": false,
      "description": "Result color"
    },
    {
      "name": "offset",
      "type": "buff(offset)",
      "required": false,
      "description": "Vertical offset from axis"
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "description": "Custom label text"
    }
  ],
  "examples": [
    {
      "scenario": "Intersection of two intervals",
      "expression": "N = nl(at(5, 2), range(-2, 10))\nI1 = interval(N, 1, 4, type(closed), c(blue))\nI2 = interval(N, 3, 7, type(closed), c(green))\nR = nlintersect(N, I1, I2, c(purple), buff(-1))"
    }
  ]
}
