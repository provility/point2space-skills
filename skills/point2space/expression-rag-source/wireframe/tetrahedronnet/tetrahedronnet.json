{"expression":"tetrahedronnet","_requires":[],"description":"Tetrahedron net (unfolded flat pattern). Standalone container.","utility":"Create a flat net of a tetrahedron","arguments":[{"name":"position","type":"at(row, col)","required":true,"description":"Canvas position"},{"name":"viewSize","type":"view(h, w)","required":false,"description":"Container size"},{"name":"sideLength","type":"number","required":true,"description":"Edge length"},{"name":"color","type":"c(color)","required":false,"description":"Edge color"},{"name":"fillColor","type":"fc(color)","required":false,"description":"Fill color"},{"name":"fillOpacity","type":"fo(number)","required":false,"description":"Fill opacity"}],"examples":[{"scenario":"Tetrahedron net","expression":"tn = tetrahedronnet(at(4,4), view(14,14), 3, c(navy), fc(lightyellow), fo(0.5))"},{"scenario":"Simple net","expression":"tn = tetrahedronnet(at(4,4), view(12,12), 2)"}]}
