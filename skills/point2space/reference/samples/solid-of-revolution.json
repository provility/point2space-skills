    "slide_1776767809493_ecl10wr6v": {
      "id": "slide_1776767809493_ecl10wr6v",
      "name": "even-function",
      "expressions": [
        "title_1=title(at(1.6,3.3),\"Understand Even Function:\",type(highlight),fc(wheat),pd(12),border(black,radius(10),shadow(22)),fs(24),ff(\"Gill Sans\"),c(black))",
        "graph_1=g2d(at(5,32),16.5,20.6,range(-5,5),range(-5,5),type(plotting))",
        "point_1=point(graph_1,1,0,s(5),defer())",
        "plot_1=implicitplot(graph_1,\"x = y^2 + 1\",type(implicit),c(slateblue),t(0))",
        "line_1=line(graph_1,\"y = 1\",c(crimson),t(0))",
        "line_2=line(graph_1,\"y = -1\",c(crimson),t(0))",
        "line_3=line(graph_1,\"x = 0\",c(black),t(0))",
        "region_1=region(graph_1,plot_1,line_2,line_1,line_3,fc(lightblue),fo(0.6),t(0))",
        "write_2=write(at(5,4),\"x = f(y) = y^2+1\",comment(\"Given Function\",buff(0.5,0),type(right)))",
        "write_1=write(at(8,4),\"f(y) = f(-y)\",fadein(0.5),notes(\"The function gives the same output for both positive and negative inputs.\"))",
        "write_3 = write(at(11,4), \"f(-y) = (-y^2) + 1 = y^2 + 1 = f(y)\")",
        "paragraph_1=paragraph(at(13.3,3.2),26.6,2.7,para_str_1,ff(\"Gill Sans\"),effect(fadein))",
        "outline_1=outline(region_1,notes(\"Now let we see how this region revolve around y- axis and form a solid \"))",
        "anchor_1=anchor(at(14.6,29.4))",
        "goto_1 = goto(\"3d-revolve\", \"revolve solid\", ref(anchor_1))",
        ""
      ],
      "paraVariables": [
        {
          "name": "para_str_1",
          "value": "If a function is even, then its graph is symmetric about the x-axis."
        }
      ]
    },
    "slide_1776767810299_lpiifu1t1": {
      "id": "slide_1776767810299_lpiifu1t1",
      "name": "3d-revolve",
      "expressions": [
        "section_1 = section(\"revolve solid\", t(2), ref(region_1))",
        "graph_1=g2d(at(3.8,29.9),19.4,21.4,range(-2,5),range(-4,4),type(plotting),t(0),snap(false))",
        "plot_1=implicitplot(graph_1,\"x = y^2 + 1\",type(implicit),c(blue),t(0))",
        "line_1=line(graph_1,\"y = 1\",t(0),c(red))",
        "line_2=line(graph_1,\"y = -1\",t(0),c(red))",
        "line_3=line(graph_1,\"x = 0\",t(0))",
        "region_1=region(graph_1,plot_1,line_1,line_2,line_3,t(0),fc(lightblue),fo(0.6))",
        "revolve_1=revolvedisk(at(3.5,3),view(21,26),region_1,axis(y),type(region),fc(lightblue),sweep(0,360),slice(0.5),fo(0.6))",
        "goto_1=goto(at(21.4,30.2),\"final\",\"final\")"
      ],
      "paraVariables": []
    },
    "slide_1776850223112_ug8hjwo4s": {
      "id": "slide_1776850223112_ug8hjwo4s",
      "name": "final",
      "expressions": [
        "section_2=section(at(0.6,2.6),\"final\")",
        "desc_1=desc(at(0.8,2.4),\"text(Standard Volume formula for cylinder:) pir^2h \")",
        "notes_3=notes(\"From the cylinder disc we know radius and height\")",
        "section_1 = section(\"Volume\", t(2), ref(desc_1))",
        "write_1=write(at(3,3),\"text(radius ) r = y^2 + 1 \",fadein(0.5))",
        "write_2=write(at(5.5,3),\"text(height )h = dy\",fadein(0.5))",
        "notes_2=notes(\"Substitute the radius and height into the volume formula.\")",
        "write_3=write(at(8,3),\"text(volume ) V = pir^2h\",fadein(0.5))",
        "write_4=write(at(10.5,2.9),\"V = pi(y^2+ 1)^2dy\",exclude(\"y^2+ 1\",1),exclude(\"dy\",1))",
        "select_1 = select(write_1, \"y^2 + 1\", 1)",
        "select_2 = select(write_2, \"dy\", 1)",
        "text_copy_1 = textcopy(write_4_select_1, select_1)",
        "text_copy_2 = textcopy(write_4_select_2, select_2, buff(-0.2, -0.1))",
        "paragraph_1=paragraph(at(13.2,2.3),21.9,2.7,para_str_1,ff(\"Gill Sans\"),effect(fadein))",
        "write_5=write(at(16,3.5),\"V = pi int_-1^1 (y^2 + 1)^2 dy\",exclude(\"(y^2 + 1)^2 dy\",1))",
        "select_3 = select(write_4, \"(y^2+ 1)^2dy\", 1)",
        "text_copy_3 = textcopy(write_5_select_1, select_3, buff(-0.2, -0.3))",
        "write_6=write(at(20,2.5),\"int_-a^a  f(y) dy=  2int_0^a  f(y) dy\",comment(\"Standard Formula For Even Function\"))",
        "aline_1=annotationline(at(1.3,26.1),at(26.8,26.1),so(0.2),fo(0.4),c(black),s(1))",
        "write_7=write(at(0.5,27),\"V = 2pi int_0^1(y^2+1)^2 dy\",notes(\"Limits Reduced Using symmetry and even function\",0.3),fs(24),t(5),stay(2))",
        "select_4 = select(write_7, \"(y^2+1)^2\", 1)",
        "outline_1=outline(select_4,notes(\"This Equation is in the form of square of a binomial\",0.38))",
        "paragraph_2=paragraph(at(0.6,39.2),17,2.9,para_str_2,ff(\"Gill Sans\"),effect(slideright),fs(19),lh(3),c(blue))",
        "tip_1 = tip(at(2.8, 36.3), at(3.9, 43.3), \"Using Square of a Binomial\",\"To expand math((y^2+1)^2= y^4 + 2y^2+ 1)\")",
        "write_8=write(at(4,27),\"(y^2+1)^2= y^4 + 2y^2+ 1\",fs(24),fadein(0.5))",
        "hide_1 = hide(tip_1)",
        "notes_4=notes(\"Substitute this expanded form into the integral to simplify the expression.\")",
        "write_9=write(at(7,27),\"V = 2pi int_0^1(y^4 + 2y^2+ 1) dy\",notes(\"Substitute this expanded form into the integral to simplify the expression.\"),fs(24),exclude(\"y^4 + 2y^2+ 1\",1),fadein(0.5))",
        "select_5 = select(write_8, \"y^4 + 2y^2+ 1\", 1)",
        "text_copy_4 = textcopy(write_9_select_1, select_5)",
        "notes_5=notes(\"Then integrate each term separately and multiply the result by 2 math(pi).\")",
        "write_10=write(at(11.5,27),\"V = 2*pi [ (y^5)/5 + 2*(y^3)/3 + 1 ]_0^1\",fs(24),exclude(\"(y^5)/5\",1),exclude(\"2*(y^3)/3\",1),exclude(\"1\",1))",
        "arrow_1=arrow(at(9.7,34.5),at(10.3,43.2),notes(\"Integrate the first term math(y^4)\"))",
        "write_11=write(at(8.5,43.9),\"y^4 = y^5 /5\",exclude(\"y^5 /5\",1),exclude(\"=\",1),exclude(\"y^4\",1))",
        "select_6 = select(write_9, \"2y^2\", 1)",
        "select_7=select(write_11,\"y^4\",1,defer())",
        "select_8 = select(write_9, \"y^4\", 1)",
        "text_copy_5 = textcopy(select_7, select_8)",
        "text_reveal_1 = textreveal(write_11_select_2)",
        "text_reveal_2 = textreveal(write_11_select_1)",
        "text_move_1 = textmove(write_10_select_1, write_11_select_1, buff(-0.2, 0))",
        "hide_2 = hide(write_11, text_copy_5, arrow_1)",
        "arrow_2=arrow(at(9.6,38.2),at(13.3,45.9),notes(\"Integrate second term math(2y^2)\"))",
        "write_12=write(at(12.4,46),\"2y^2 = 2. (y^3)/3\",exclude(\"2y^2\",1),exclude(\"=\",1),exclude(\"2. (y^3)/3\",1))",
        "text_copy_6 = textcopy(write_12_select_1, select_6, buff(-0.1, 0))",
        "text_reveal_3 = textreveal(write_12_select_2)",
        "text_reveal_4 = textreveal(write_12_select_3)",
        "text_move_2 = textmove(write_10_select_2, write_12_select_3)",
        "hide_3 = hide(write_12, arrow_2, write_12_select_1, text_copy_6)",
        "notes_6=notes(\"Integrate the last term, which is just 1, so its integral is 1.\")",
        "text_reveal_5=textreveal(write_10_select_3,c(black))",
        "notes_7=notes(\"Substitute the limits math(y=1) and math(y=0) into the expression and subtract to find the value.\")",
        "write_13=write(at(15.5,27),\"V = 2*pi [ ((1^5)/5 + 2*(1^3)/3 + 1) - 0 ]\",fs(22),t(5))",
        "write_14=write(at(19,27),\"V = 2*pi [ (1)/5 + 2/3 + 1 ]\",fs(22),fadein(0.5))",
        "notes_8=notes(\"Take the LCM of 5,3, and 1 (which is 15) and combine the terms into a single fraction.\")",
        "write_15=write(at(19,38),\"=> 2*pi [ (3 + 10 + 15)/15 ]\",fs(22),fadein(0.5))",
        "notes_9=notes(\"Combine the numerator and simplify:\")",
        "write_16=write(at(22.8,27),\"V = 2*pi * (28/15)\",fs(22))",
        "write_17=write(at(23.5,35.5),\"=>56pi//15\")",
        "paragraph_3=paragraph(at(22.7,41.3),7.3,2.5,para_str_3,ff(\"Gill Sans\"),effect(fadein),c(blue))"
      ],
