        "G2=g2d(at(3,24.5),25,25,type(plotting))",
        "dd_eq2=dropdown(at(6.2,4.8),\"eq2\",value(\"x^2/a^2 + y^2/b^2 = 1\",\"(x^2 + y^2)^2 = a^2*(x^2 - y^2)\",\"x^3 + y^3 = a*x*y\"),\"Curve\",type(math),ref(1))",
        "desc_1=desc(at(9,4.5),\"text(Let’s define values for each variable in the above equation..)\",fs(20))",
        "varanim_a=variableanimator(at(12,5),\"a\",1,3)",
        "varanim_b=variableanimator(at(15.5,5),\"b\",2,4)",
        "plot_1=implicitplot(G2,eq2,c(teal),notes(\"Now, draw the plot for the selected equation.\"))",
        "obrace_1=overbrace(at(11.9,10.1),at(17,10.2),c(black),s(1))",
        "desc_2=desc(at(14,11),\"text(Watch the implicit curve reshape as the parameters change.)\",fs(16),c(maroon))",
        "play_a=playanimator(varanim_a)",
        "play_b=playanimator(varanim_b)",
        ""
      ],
      "paraVariables": []
    },
