{
  "assets": [],
  "slides": {
    "slide_plot_explicit": {
      "id": "slide_plot_explicit",
      "name": "Explicit Plot",
      "expressions": [
        "title_1=title(at(1.2,13.1),\"Explicit Plot\",type(slideup),fc(steelblue),pd(10),border(steelblue,radius(12),shadow(12)),fs(28),ff(\"Gill Sans\"),c(white))",
        "G1=g2d(at(2.5,28.5),22,22,type(plotting))",
        "dd_eq1=dropdown(at(6.2,3.8),\"eq1\",value(\"a*x^2 + b*x + c\",\"a*sin(b*x)\",\"a*exp(-b*x^2)\"),\"f(x)\",type(math),ref(1))",
        "desc_1=desc(at(9.5,3.5),\"text(Let’s define values for each variable in the above equation.)\",fs(20))",
        "varanim_a=variableanimator(at(12.5,3.5),\"a\",1,3)",
        "varanim_b=variableanimator(at(16,3.5),\"b\",2,5)",
        "varanim_c=variableanimator(at(19.5,3.5),\"c\",-3,2)",
        "plot_1=plot(G1,eq1,c(steelblue),notes(\"Now, draw the plot for the selected equation.\"))",
        "obrace_1=overbrace(at(12.5,9.3),at(21.2,9.4),\"\",c(steelblue))",
        "paragraph_1=paragraph(at(13.2,11.3),11.8,6.8,para_str_1,ff(\"Gill Sans\"),effect(fadein),c(steelblue))",
        "play_a=playanimator(varanim_a)",
        "play_b=playanimator(varanim_b)",
        "play_c=playanimator(varanim_c)",
        "desc_2=desc(at(23,3.5),\"text(Animate parameters to see the curve transform)\",fs(20))",
        ""
      ],
      "paraVariables": [
        {
          "name": "para_str_1",
          "value": "Now, animate the values and observe how the graph changes.\n"
        }
      ]
    },
    "slide_plot_implicit": {
      "id": "slide_plot_implicit",
      "name": "Implicit Curve",
      "expressions": [
